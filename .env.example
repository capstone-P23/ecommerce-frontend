# ============== Frontend (Next.js) ==============

# 백엔드 API 베이스 URL
# 로컬: http://localhost:8080  / Vercel: 배포된 BE URL 로 교체
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# MSW 모킹 강제 활성화 (옵션). dev 는 자동 on, preview/production 은 기본 off.
# NEXT_PUBLIC_API_MOCKING=enabled


# ============== Docker Compose (Backend + DB) ==============
# 실값은 BE 팀이 dev 용으로 공유. .env (gitignored) 에 입력.
# 이 파일에는 절대 실값을 적지 말 것.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# --- JWT (BE 토큰 서명) ---
JWT_SECRET=

# --- OAuth: Google (필수) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: Kakao / Naver (BE 가 dev 단계에서는 placeholder 사용) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
